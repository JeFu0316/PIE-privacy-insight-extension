{
  "manifest_version": 3,
  "name": "Toolingo - Privacy Insight",
  "version": "2.1.0",
  "description": "Toolingo helps you understand website cookie usage, third-party tracking, and connection security — on your device.",
  "permissions": [
    "cookies",
    "tabs",
    "webRequest",
    "storage",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "toolingo16.png",
    "32": "toolingo32.png",
    "48": "toolingo128.png",
    "128": "toolingo128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "toolingo16.png",
      "32": "toolingo32.png",
      "48": "toolingo128.png",
      "128": "toolingo128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
